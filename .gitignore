vendor/

.config/*
!.config/gh/
# gh writes auth tokens into hosts.yml when the OS keyring is unavailable; never
# track it in this public repo. Only config.yml (no secrets) is versioned.
.config/gh/hosts.yml
!.config/git/
!.config/latex/
!.config/claude/
!.config/zed/

# Override global gitignore to track CLAUDE.md in this repo
!CLAUDE.md
!.config/claude/CLAUDE.md
